HOST=0.0.0.0
PORT=1337
# URL exacte du site (schéma + domaine, sans slash final). Ex. https://api.example.com
PUBLIC_URL=https://api.la-peche-evenements.staginglab.fr
# Origines CORS supplémentaires (virgules). Les domaines staging front + API sont déjà inclus dans config/middlewares.ts
# CORS_ORIGIN=https://autre-domaine.fr
# true derrière un reverse proxy (Nginx, Traefik) qui envoie X-Forwarded-*
TRUST_PROXY=true
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
# Secret JWT admin + plugin users-permissions (config/plugins.ts)
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified
